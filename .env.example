# ============================================
# CONFIGURAÇÃO DO SISTEMA DE CONTROLE DE ESTOQUE
# ============================================
# Copie este arquivo para .env e ajuste os valores
# ============================================

# PostgreSQL Database
POSTGRES_DB=estoque
POSTGRES_USER=estoque_user
POSTGRES_PASSWORD=senha_segura_forte_aqui_123

# Backend API
NODE_ENV=development
BACKEND_PORT=3001
JWT_SECRET=seu_jwt_secret_super_seguro_aqui_456
JWT_EXPIRES_IN=7d

# Frontend Application
FRONTEND_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:3001/api

# pgAdmin (opcional - desenvolvimento)
PGADMIN_DEFAULT_EMAIL=admin@estoque.com
PGADMIN_DEFAULT_PASSWORD=admin123
PGADMIN_PORT=5050

# ============================================
# CONFIGURAÇÕES AVANÇADAS
# ============================================

# Database Connection Pool
DB_POOL_MIN=2
DB_POOL_MAX=10

# Logging
LOG_LEVEL=info
LOG_FORMAT=json

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000  # 15 minutos
RATE_LIMIT_MAX_REQUESTS=100

# CORS
CORS_ORIGIN=http://localhost:3000,http://localhost:3001

# ============================================
# CONFIGURAÇÕES DE PRODUÇÃO
# ============================================
# Descomente e ajuste para produção:

# NODE_ENV=production
# POSTGRES_PASSWORD=senha_muito_forte_producao_789
# JWT_SECRET=seu_jwt_secret_producao_abc123
# NEXT_PUBLIC_API_URL=https://api.estoque.com.br/api
# CORS_ORIGIN=https://estoque.com.br

# ============================================
# NOTAS IMPORTANTES:
# ============================================
# 1. NUNCA commit arquivos .env no Git
# 2. Use senhas fortes em produção
# 3. Em produção, use variáveis de ambiente do servidor
# 4. Mantenha os secrets seguros
# 5. Para produção, considere usar um serviço de secrets
#    como AWS Secrets Manager, HashiCorp Vault, etc.