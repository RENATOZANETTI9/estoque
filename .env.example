# Environment Configuration for Estoque Application
# Copy this file to .env and .env.production and update values

# Database Configuration
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/estoque

# Backend Configuration
PORT=3001
NODE_ENV=development
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d

# Frontend Configuration
REACT_APP_API_URL=http://localhost:8080/api
REACT_APP_NAME=Estoque System

# Docker Configuration
COMPOSE_PROJECT_NAME=estoque

# PostgreSQL Configuration
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=estoque

# Nginx Configuration
NGINX_PORT=8080

# Application Settings
APP_NAME=Estoque Management System
APP_VERSION=1.0.0
APP_DESCRIPTION=Sistema de gerenciamento de estoque

# Security Settings
CORS_ORIGIN=http://localhost:3000
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_LEVEL=info
LOG_FORMAT=combined

# Email Configuration (Optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM=noreply@estoque.com

# File Upload
MAX_FILE_SIZE=10485760
UPLOAD_PATH=./uploads

# Redis Configuration (Optional)
REDIS_URL=redis://localhost:6379

# Monitoring
ENABLE_METRICS=true
METRICS_PORT=9090

# Development Settings
DEBUG=true
ENABLE_SWAGGER=true

# Production Overrides (for .env.production)
# NODE_ENV=production
# JWT_SECRET=change-this-to-a-strong-random-secret
# DEBUG=false
# ENABLE_SWAGGER=false